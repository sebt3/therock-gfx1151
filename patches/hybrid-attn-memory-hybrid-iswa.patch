 llama_pos llama_memory_hybrid_iswa::seq_pos_max(llama_seq_id seq_id) const {
     // the max of the total cache is the min of the two caches' max values
-    return std::min(mem_attn->seq_pos_max(seq_id), mem_recr->seq_pos_max(seq_id));
+    const auto attn_max = mem_attn->seq_pos_max(seq_id);
+    const auto recr_max = mem_recr->seq_pos_max(seq_id);
+
+    // After cell_zero() the recurrent pos_max is -1 while attention KV
+    // may still hold a valid prefix.  Return the attention max in that
+    // case rather than forcing the result to -1.
+    if (recr_max < 0) {
+        return attn_max;
+    }
+
+    return std::min(attn_max, recr_max);
 }
 

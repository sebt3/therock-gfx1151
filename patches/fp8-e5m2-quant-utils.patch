+  // =========================================================================
+  // E5M2 FP8 conversion functions for KV cache on RDNA 3+ (gfx11xx)
+  //
+  // RDNA 3+ hardware only supports FP8 E5M2 natively. The E4M3 format
+  // causes Triton JIT compilation failures:
+  //   "type fp8e4nv not supported in this architecture"
+  // These overloads mirror the E4M3 ones but use __hip_fp8_e5m2 types.
+  // =========================================================================
+  #ifdef ENABLE_FP8
+
+// E5M2 generic templates (fallback: identity)
+template <typename Tout, typename Tin>
+__inline__ __device__ Tout vec_conversion_e5m2(const Tin& x) {
+  return x;
+}
+
+template <typename Tout, typename Tin>
+__inline__ __device__ Tout scaled_vec_conversion_e5m2(const Tin& x,
+                                                       const float scale) {
+  return x;
+}
+
+// E5M2 fp8 -> bf16
+template <>
+__inline__ __device__ __nv_bfloat16
+vec_conversion_e5m2<__nv_bfloat16, uint8_t>(const uint8_t& a) {
+  fp8_e5m2_type f8;
+  f8.__x = a;
+  return __float2bfloat16(static_cast<float>(f8));
+}
+
+// E5M2 fp8x2 -> bf16x2
+template <>
+__inline__ __device__ __nv_bfloat162
+vec_conversion_e5m2<__nv_bfloat162, uint16_t>(const uint16_t& a) {
+  __nv_bfloat162 res;
+  res.x = vec_conversion_e5m2<__nv_bfloat16, uint8_t>((uint8_t)a);
+  res.y = vec_conversion_e5m2<__nv_bfloat16, uint8_t>((uint8_t)(a >> 8U));
+  return res;
+}
+
+// E5M2 fp8 -> float
+template <>
+__inline__ __device__ float vec_conversion_e5m2<float, uint8_t>(
+    const uint8_t& a) {
+  fp8_e5m2_type f8;
+  f8.__x = a;
+  return static_cast<float>(f8);
+}
+
+// E5M2 scaled: bf16 -> fp8
+template <>
+__inline__ __device__ uint8_t
+scaled_vec_conversion_e5m2<uint8_t, __nv_bfloat16>(
+    const __nv_bfloat16& a, float scale) {
+  return __hip_cvt_float_to_fp8(__bfloat162float(a) / scale,
+                                __HIP_SATFINITE, __HIP_E5M2);
+}
+
+// E5M2 scaled: bf16x2 -> fp8x2
+template <>
+__inline__ __device__ uint16_t
+scaled_vec_conversion_e5m2<uint16_t, __nv_bfloat162>(
+    const __nv_bfloat162& a, float scale) {
+  union {
+    uint8_t ui8[2];
+    uint16_t ui16;
+  } tmp;
+  tmp.ui8[0] = scaled_vec_conversion_e5m2<uint8_t, __nv_bfloat16>(a.x, scale);
+  tmp.ui8[1] = scaled_vec_conversion_e5m2<uint8_t, __nv_bfloat16>(a.y, scale);
+  return tmp.ui16;
+}
+
+// E5M2 scaled: float -> fp8
+template <>
+__inline__ __device__ uint8_t
+scaled_vec_conversion_e5m2<uint8_t, float>(const float& a, float scale) {
+  return __hip_cvt_float_to_fp8(a / scale,
+                                __HIP_SATFINITE, __HIP_E5M2);
+}
+
+// E5M2 scaled: fp8 -> bf16
+template <>
+__inline__ __device__ __nv_bfloat16
+scaled_vec_conversion_e5m2<__nv_bfloat16, uint8_t>(const uint8_t& a,
+                                                    float scale) {
+  fp8_e5m2_type f8;
+  f8.__x = a;
+  return __float2bfloat16(static_cast<float>(f8) * scale);
+}
+
+// E5M2 scaled: fp8x2 -> bf16x2
+template <>
+__inline__ __device__ __nv_bfloat162
+scaled_vec_conversion_e5m2<__nv_bfloat162, uint16_t>(const uint16_t& a,
+                                                     float scale) {
+  __nv_bfloat162 res;
+  res.x = scaled_vec_conversion_e5m2<__nv_bfloat16, uint8_t>((uint8_t)a, scale);
+  res.y = scaled_vec_conversion_e5m2<__nv_bfloat16, uint8_t>(
+      (uint8_t)(a >> 8U), scale);
+  return res;
+}
+
+// E5M2 scaled: fp8 -> float
+template <>
+__inline__ __device__ float scaled_vec_conversion_e5m2<float, uint8_t>(
+    const uint8_t& a, float scale) {
+  fp8_e5m2_type f8;
+  f8.__x = a;
+  return static_cast<float>(f8) * scale;
+}
+
+// E5M2 scaled: fp8x4 -> bf16_4_t
+template <>
+__inline__ __device__ bf16_4_t
+scaled_vec_conversion_e5m2<bf16_4_t, uint32_t>(const uint32_t& a, float scale) {
+  bf16_4_t res;
+  res.x = scaled_vec_conversion_e5m2<__nv_bfloat162, uint16_t>((uint16_t)a, scale);
+  res.y = scaled_vec_conversion_e5m2<__nv_bfloat162, uint16_t>(
+      (uint16_t)(a >> 16U), scale);
+  return res;
+}
+
+// E5M2 scaled: fp8x8 -> bf16_8_t
+template <>
+__inline__ __device__ bf16_8_t
+scaled_vec_conversion_e5m2<bf16_8_t, uint2>(const uint2& a, float scale) {
+  bf16_4_t tmp1, tmp2;
+  tmp1 = scaled_vec_conversion_e5m2<bf16_4_t, uint32_t>(a.x, scale);
+  tmp2 = scaled_vec_conversion_e5m2<bf16_4_t, uint32_t>(a.y, scale);
+  bf16_8_t res;
+  res.x = tmp1.x;
+  res.y = tmp1.y;
+  res.z = tmp2.x;
+  res.w = tmp2.y;
+  return res;
+}
+
+// E5M2 scaled: bf16x4 -> fp8x4
+template <>
+__inline__ __device__ uint32_t
+scaled_vec_conversion_e5m2<uint32_t, bf16_4_t>(const bf16_4_t& a, float scale) {
+  union {
+    uint16_t ui16[2];
+    uint32_t ui32;
+  } tmp;
+  tmp.ui16[0] = scaled_vec_conversion_e5m2<uint16_t, __nv_bfloat162>(a.x, scale);
+  tmp.ui16[1] = scaled_vec_conversion_e5m2<uint16_t, __nv_bfloat162>(a.y, scale);
+  return tmp.ui32;
+}
+
+// E5M2 scaled: bf16x8 -> fp8x8
+template <>
+__inline__ __device__ uint2
+scaled_vec_conversion_e5m2<uint2, bf16_8_t>(const bf16_8_t& a, float scale) {
+  uint2 res;
+  res.x = scaled_vec_conversion_e5m2<uint32_t, bf16_4_t>({a.x, a.y}, scale);
+  res.y = scaled_vec_conversion_e5m2<uint32_t, bf16_4_t>({a.z, a.w}, scale);
+  return res;
+}
+
+// E5M2 scaled: float2 -> fp8x2 (needed by Float SRC_DTYPE dispatch)
+template <>
+__inline__ __device__ uint16_t
+scaled_vec_conversion_e5m2<uint16_t, float2>(const float2& a, float scale) {
+  union {
+    uint8_t ui8[2];
+    uint16_t ui16;
+  } tmp;
+  tmp.ui8[0] = scaled_vec_conversion_e5m2<uint8_t, float>(a.x, scale);
+  tmp.ui8[1] = scaled_vec_conversion_e5m2<uint8_t, float>(a.y, scale);
+  return tmp.ui16;
+}
+
+// E5M2 scaled: float4 -> fp8x4 (needed by Float SRC_DTYPE dispatch)
+template <>
+__inline__ __device__ uint32_t
+scaled_vec_conversion_e5m2<uint32_t, Float4_>(const Float4_& a, float scale) {
+  union {
+    uint16_t ui16[2];
+    uint32_t ui32;
+  } tmp;
+  tmp.ui16[0] = scaled_vec_conversion_e5m2<uint16_t, float2>(a.x, scale);
+  tmp.ui16[1] = scaled_vec_conversion_e5m2<uint16_t, float2>(a.y, scale);
+  return tmp.ui32;
+}
+
+// E5M2 fp8x2 -> float2 (needed by Float SRC_DTYPE dispatch)
+template <>
+__inline__ __device__ float2 vec_conversion_e5m2<float2, uint16_t>(
+    const uint16_t& a) {
+  float2 res;
+  res.x = vec_conversion_e5m2<float, uint8_t>((uint8_t)a);
+  res.y = vec_conversion_e5m2<float, uint8_t>((uint8_t)(a >> 8U));
+  return res;
+}
+
+// E5M2 fp8x4 -> float4 (needed by Float SRC_DTYPE dispatch)
+template <>
+__inline__ __device__ Float4_ vec_conversion_e5m2<Float4_, uint32_t>(
+    const uint32_t& a) {
+  Float4_ res;
+  res.x = vec_conversion_e5m2<float2, uint16_t>((uint16_t)a);
+  res.y = vec_conversion_e5m2<float2, uint16_t>((uint16_t)(a >> 16U));
+  return res;
+}
+
+// E5M2 scaled: fp8x2 -> float2
+template <>
+__inline__ __device__ float2 scaled_vec_conversion_e5m2<float2, uint16_t>(
+    const uint16_t& a, float scale) {
+  float2 res;
+  res.x = scaled_vec_conversion_e5m2<float, uint8_t>((uint8_t)a, scale);
+  res.y = scaled_vec_conversion_e5m2<float, uint8_t>((uint8_t)(a >> 8U), scale);
+  return res;
+}
+
+// E5M2 scaled: fp8x4 -> float4
+template <>
+__inline__ __device__ Float4_ scaled_vec_conversion_e5m2<Float4_, uint32_t>(
+    const uint32_t& a, float scale) {
+  Float4_ res;
+  res.x = scaled_vec_conversion_e5m2<float2, uint16_t>((uint16_t)a, scale);
+  res.y = scaled_vec_conversion_e5m2<float2, uint16_t>((uint16_t)(a >> 16U), scale);
+  return res;
+}
+
+// E5M2 scaled: fp8x4 -> float4 (native HIP type)
+template <>
+__inline__ __device__ float4
+scaled_vec_conversion_e5m2<float4, uint32_t>(const uint32_t& a, float scale) {
+  Float4_ res = scaled_vec_conversion_e5m2<Float4_, uint32_t>(a, scale);
+  return {res.x.x, res.x.y, res.y.x, res.y.y};
+}
+
+// E5M2 scaled: fp8x8 -> float8
+template <>
+__inline__ __device__ Float8_ scaled_vec_conversion_e5m2<Float8_, uint2>(
+    const uint2& a, float scale) {
+  Float8_ res;
+  res.x = scaled_vec_conversion_e5m2<float2, uint16_t>(a.x, scale);
+  res.y = scaled_vec_conversion_e5m2<float2, uint16_t>(a.y, scale);
+  return res;
+}
+
+  #endif  // ENABLE_FP8
+

+    // Clear ALL rows of the rs_zero cell (primary + snapshot planes).
+    //
+    // Recurrent tensor layout (each row = state_size elements):
+    //   [primary_cell_0, ..., primary_cell_{N-1},
+    //    snap_1_cell_0, ..., snap_1_cell_{N-1},
+    //    ...,
+    //    snap_{K}_cell_0, ..., snap_{K}_cell_{N-1}]
+    // where N = rs_size, K = n_rs_seq.
+    //
+    // A cell's rows are spaced rs_size apart.  The old code only zeroed the
+    // primary row of rs_zero, leaving snapshot rows stale.  When seq_rm
+    // succeeds via partial rollback (without hitting cell_zero), the stale
+    // snapshot data could later be read by s_copy through a non-zero rs_idx,
+    // mixing old-topic recurrent state into new-topic decoding.
+    //
+    // Now every plane belonging to the rs_zero cell is zeroed so that no
+    // matter which rs_idx s_copy reads from, it gets a clean initial state.
+    // This is a no-op when rs_zero < 0.
+    if (rs_zero >= 0 && rs_size > 0) {
+        GGML_ASSERT(states->ne[1] % rs_size == 0);
+        const uint32_t rows_per_cell = states->ne[1] / rs_size;
+        for (uint32_t p = 0; p < rows_per_cell; p++) {
+            const size_t row = (size_t)(uint32_t)rs_zero + (size_t)p * (size_t)rs_size;
+            ggml_tensor * plane = ggml_view_1d(ctx0, states, state_size, row * states->nb[1]);
+            ggml_build_forward_expand(gf, ggml_scale_inplace(ctx0, plane, 0));
+        }
+    }
 

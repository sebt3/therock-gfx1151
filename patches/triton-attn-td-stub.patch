+# Resolve make_tensor_descriptor with fallback for Triton < 3.3.
+# triton_unified_attention.py calls make_tensor_descriptor directly in
+# @triton.jit helpers (_load_q_td, _load_kv_tile_td, _store_output_td).
+# These are XPU-only (USE_TD=False on CUDA/ROCm), but Triton's JIT AST
+# visitor parses all nodes before constexpr branch pruning, triggering
+# AttributeError on Triton 3.0.0 which lacks make_tensor_descriptor.
+# FLA ops (fla/ops/op.py) already handle this via upstream PR #37088/#38981,
+# but unified_attention was not patched. Mirrors the FLA ops pattern.
+if hasattr(tl, "make_tensor_descriptor"):
+    _make_tensor_descriptor = tl.make_tensor_descriptor
+elif hasattr(tl, "_experimental_make_tensor_descriptor"):
+    _make_tensor_descriptor = tl._experimental_make_tensor_descriptor
+else:
+
+    @triton.jit
+    def _make_tensor_descriptor(base, shape, strides, block_shape, _builder=None):
+        return None
 
